<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.repository.IncomeCategoryRepository">

    <select id="findAll" resultType="com.example.demo.models.IncomeCategory">
        SELECT * FROM INCOME_CATEGORIES
    </select>

    <select id="findByRange" resultType="long">
        SELECT ID FROM INCOME_CATEGORIES WHERE RANGE = #{range}
    </select>

</mapper>
