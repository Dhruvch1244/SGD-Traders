<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.repository.InstrumentRepository">

    <select id="findAll" resultType="com.example.demo.models.Instrument">
        SELECT * FROM instruments
    </select>

    <select id="findById" resultType="com.example.demo.models.Instrument">
        SELECT * FROM instruments WHERE INSTRUMENTID = #{id}
    </select>

    <select id="findByCriteria" resultType="com.example.demo.models.Instrument">
        SELECT * FROM instruments WHERE 1=1
        <if test="description != null">
            AND LOWER(description) LIKE LOWER('%' || #{description} || '%')
        </if>
        <if test="category != null">
            AND LOWER(categoryid) = LOWER(#{category})
        </if>
    </select>

</mapper>
