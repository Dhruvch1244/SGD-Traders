<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.repository.InvestmentDurationRepository">

    <select id="findAll" resultType="com.example.demo.models.InvestmentDuration">
        SELECT * FROM INVESTMENT_DURATIONS
    </select>

    <select id="findByDuration" resultType="long">
        SELECT ID FROM INVESTMENT_DURATIONS WHERE DURATION = #{duration}
    </select>

</mapper>
