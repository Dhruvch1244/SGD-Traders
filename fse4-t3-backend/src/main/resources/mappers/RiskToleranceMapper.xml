<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.repository.RiskToleranceRepository">

    <select id="findAll" resultType="com.example.demo.models.RiskTolerance">
        SELECT * FROM RISK_TOLERANCES
    </select>

    <select id="findByName" resultType="long">
        SELECT ID FROM RISK_TOLERANCES WHERE NAME = #{name}
    </select>

</mapper>
